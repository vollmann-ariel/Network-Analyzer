<Window x:Class="NETpro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NETpro"
        xmlns:conv="clr-namespace:NETpro.Converters"
        mc:Ignorable="d"
        Title="NETpro" Height="500" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </Window.Resources>
    <DockPanel Margin="12">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right"
                    Content="Actualizar"
                    Padding="12,4"
                    Command="{Binding RefreshCommand}" />
            <Button DockPanel.Dock="Right"
                    Content="Exportar CSV"
                    Padding="12,4"
                    Margin="0,0,8,0"
                    Click="OnExportCsvClick" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                <CheckBox Content="Auto-actualizar cada"
                          VerticalAlignment="Center"
                          IsChecked="{Binding AutoRefreshEnabled}" />
                <TextBox Width="40" Margin="4,0"
                         VerticalAlignment="Center"
                         Text="{Binding AutoRefreshIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="s" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="Dispositivos en la red local" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
        </DockPanel>

        <ProgressBar DockPanel.Dock="Top" Height="4" Margin="0,0,0,12"
                     IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,12" TextWrapping="Wrap" Foreground="DarkRed"
                   Text="{Binding ErrorMessage}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}" />

        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,12" Foreground="Gray"
                   Text="No se encontraron otros dispositivos."
                   Visibility="{Binding ShowEmptyHint, Converter={StaticResource BoolToVis}}" />

        <DataGrid ItemsSource="{Binding Devices}"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" IsReadOnly="True" Width="130" />
                <DataGridTextColumn Header="MAC" Binding="{Binding MacAddress}" IsReadOnly="True" Width="150" />
                <DataGridTextColumn Header="Fabricante" Binding="{Binding Vendor}" IsReadOnly="True" Width="*" />
                <DataGridTextColumn Header="Ping" Binding="{Binding PingDisplay}" IsReadOnly="True" Width="115" />
                <DataGridTextColumn Header="Referencia" Binding="{Binding Label}" Width="160" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
