<Window x:Class="NETpro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NETpro"
        xmlns:conv="clr-namespace:NETpro.Converters"
        mc:Ignorable="d"
        Title="NETpro" Height="500" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
    </Window.Resources>
    <DockPanel Margin="12">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right"
                    Content="Actualizar"
                    Padding="12,4"
                    Command="{Binding RefreshCommand}" />
            <TextBlock Text="Dispositivos en la red local" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
        </DockPanel>

        <ProgressBar DockPanel.Dock="Top" Height="4" Margin="0,0,0,12"
                     IsIndeterminate="True"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,12" TextWrapping="Wrap" Foreground="DarkRed"
                   Text="{Binding ErrorMessage}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}" />

        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,12" Foreground="Gray"
                   Text="No se encontraron otros dispositivos."
                   Visibility="{Binding ShowEmptyHint, Converter={StaticResource BoolToVis}}" />

        <DataGrid ItemsSource="{Binding Devices}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="140" />
                <DataGridTextColumn Header="MAC" Binding="{Binding MacAddress}" Width="160" />
                <DataGridTextColumn Header="Fabricante" Binding="{Binding Vendor}" Width="*" />
                <DataGridCheckBoxColumn Header="Este equipo" Binding="{Binding IsSelf}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
